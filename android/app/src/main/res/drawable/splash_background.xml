<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo azul marino -->
    <item>
        <color android:color="@color/brand_bg" />
    </item>

    <!-- Tau dorada centrada (brazo horizontal) -->
    <item
        android:gravity="center"
        android:top="-60dp"
        android:bottom="60dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_gold" />
            <corners android:radius="6dp" />
            <size android:width="120dp" android:height="14dp" />
        </shape>
    </item>

    <!-- Tau dorada centrada (fuste vertical) -->
    <item
        android:gravity="center"
        android:top="0dp"
        android:bottom="-60dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_gold" />
            <corners android:radius="5dp" />
            <size android:width="14dp" android:height="120dp" />
        </shape>
    </item>

</layer-list>
